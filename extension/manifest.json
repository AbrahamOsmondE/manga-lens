{
  "manifest_version": 3,
  "name": "MangaLens",
  "version": "1.0.0",
  "description": "Translate Japanese manga pages to English in your browser",
  "permissions": ["activeTab", "storage", "scripting", "identity"],
  "host_permissions": ["<all_urls>"],
  "oauth2": {
    "client_id": "920084486170-7obru0qj88ne0fj6reaom34t390975ft.apps.googleusercontent.com",
    "scopes": ["openid", "email", "profile"]
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
