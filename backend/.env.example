# Never commit the real .env file

# ── Lightweight Translator ────────────────────────────────────────────────────
GOOGLE_VISION_API_KEY=your_google_vision_api_key_here

# ── Google OAuth ──────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# ── Database (Supabase) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── GCP (used by Makefile deploy targets) ────────────────────────────────────
GCE_INSTANCE=manga-lens-server      # VM instance name in GCP Console
GCE_ZONE=asia-southeast1-b          # zone the VM was created in (Singapore)
GCE_IP=                             # external IP — fill in after VM is created
