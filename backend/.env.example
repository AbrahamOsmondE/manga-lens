# Never commit the real .env file

# ── Translator ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# ── Auth proxy ────────────────────────────────────────────────────────────────
MANGA_API_KEY=your_secret_api_key_here   # generate with: make generate-key

# ── GCP (used by Makefile deploy targets) ────────────────────────────────────
GCE_INSTANCE=manga-lens-server           # VM instance name in GCP Console
GCE_ZONE=us-central1-a                   # zone the VM was created in
GCE_IP=                                  # external IP — fill in after VM is created
